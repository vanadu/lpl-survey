{
  "name": "n2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "export": "npm run build && next export -o _static",
    "build-survey": "node scripts/merge-surveys.js && npm run dev",
    "build-schema": "node scripts/buildSurveySchema.js",
    "build-format": "node scripts/schema-to-format-map.js",
    "build-registry-generated": "node scripts/generate-registry.js --in data/master-survey.json --out helpers/registry.generated.json",
    "build-registry-manual-init": "node scripts/init-registry-manual.js --generated helpers/registry.generated.json --manual helpers/registry.manual.json",
    "build-registry-all": "npm run build:survey && npm run build:registry:manual:init",
    "merge-surveys": "node scripts/merge-surveys.js --lang",
    "merge-surveys-en": "node scripts/merge-surveys.js --lang en-US",
    "merge-surveys-de": "node scripts/merge-surveys.js --lang de-DE",
    "refresh-survey": "node scripts/refresh-survey.mjs",
    "generate-browse": "node scripts/generate-browse.js",
    "loc-extract": "node helpers/i18n/extractSurveyPageContent.js --batch",
    "loc-split": "node helpers/i18n/splitLocales.js",
    "loc-build": "npm run i18n:extract && npm run i18n:split",
    "loc-paths-de": "node helpers/projectPaths.js --lang de-DE"
  },
  "dependencies": {
    "@analytics/google-tag-manager": "^0.5.3",
    "@emailjs/browser": "^3.11.0",
    "@getbrevo/brevo": "^3.0.1",
    "@mdx-js/loader": "^2.3.0",
    "@mdx-js/react": "^2.3.0",
    "@next/mdx": "^13.5.2",
    "analytics": "^0.8.1",
    "dotenv": "^16.3.1",
    "eslint": "8.37.0",
    "framer-motion": "^11.0.25",
    "gray-matter": "^4.0.3",
    "next": "^14.2.23",
    "next-mdx-remote": "^4.4.1",
    "next-seo": "^6.5.0",
    "react": "^18.3.1",
    "react-cookie-consent": "^9.0.0",
    "react-dom": "^18.3.1",
    "react-google-recaptcha": "^3.1.0",
    "react-icons": "^5.5.0",
    "react-modal": "^3.16.1",
    "react-tabs": "^6.0.1",
    "react-tooltip": "^5.10.5",
    "stylelint-config-recommended-scss": "^10.0.0",
    "survey-core": "^2.5.5",
    "survey-react-ui": "^2.5.5"
  },
  "devDependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "eslint-config-next": "^14.2.23",
    "sass": "^1.60.0",
    "sharp": "^0.34.5",
    "stylelint": "^15.4.0",
    "stylelint-config-css-modules": "^4.2.0",
    "stylelint-config-idiomatic-order": "^9.0.0",
    "stylelint-config-property-sort-order-smacss": "^9.1.0",
    "stylelint-config-standard": "^32.0.0",
    "stylelint-config-standard-scss": "^8.0.0",
    "stylelint-order": "^6.0.3",
    "stylelint-prettier": "^3.0.0",
    "tree-kill": "^1.2.2"
  },
  "stylelint": {
    "extends": "@company/stylelint-config"
  }
}

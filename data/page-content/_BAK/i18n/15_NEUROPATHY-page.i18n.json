    "NeuropathyHeading.html": {
      "source": "<h2>Hind-end weakness and polyneuropathy</h2>",
      "target": ""
    },
    "NeuropathyText.html": {
      "source": "<p><b>NOTE:</b> Polyneuropathy refers to the weakening of motor function due to neurological degeneration, particularly in the hind end. Symptoms can include hind-end weakness and incontinence. Younger dogs with idiopathic LP often don't suffer from LP-related polyneuropathy.</p>",
      "target": ""
    },

{
  "name": "PRIMARY-page",
  "elements": [
    {
      "type": "panel",
      "name": "PrimaryCard1Panel",
      "elements": [
        {
          "type": "html",
          "name": "PrimaryHeading",
          "html": "<h2>Your current primary veterinarian and {CmpnName}'s LP/GOLPP</h2>"
        },
        {
          "type": "html",
          "name": "PrimaryText",
          "html": "<p>This section asks questions about how your current primary veterinarian handled {CmpnName}'s LP/GOLPP symptoms.</p>"
        },
        {
          "type": "panel",
          "name": "PrimaryInflammationPanel",
          "title": "",
          "elements": [
            {
              "type": "radiogroup",
              "name": "PrimaryInflammation",
              "title": "Did your current primary veterinarian observe any inflammation, irritation, or infection in the larynx/pharynx area?",
              "isRequired": true,
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "radiogroup",
              "name": "PrimaryReflux",
              "title": "Did your current primary veterinarian mention reflux (GERD) or esophageal dysfunction in relation to {CmpnName}'s symptoms?",
              "isRequired": true,
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "radiogroup",
              "name": "PrimaryDidDiscuss",
              "title": "Did your current primary vet discuss LP/GOLPP as a possible cause of {CmpnName}'s symptoms? ",
              "isRequired": true,
              "choices": [
                {
                  "value": "NO_MENTION",
                  "text": "No, did not mention LP/GOLPP at all"
                },
                {
                  "value": "POSSIBLY",
                  "text": "Said {CmpnName}'s symptoms were possibly due to LP/GOLPP"
                },
                {
                  "value": "DEFINITELY",
                  "text": "Said {CmpnName}'s symptoms were definitely due to LP/GOLPP"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            }
          ]
        }
      ]
    },
    {
      "type": "panel",
      "name": "PrimaryCard2Panel",
      "elements": [
        {
          "type": "panel",
          "name": "PrimaryInfoPanel",
          "title": "",
          "elements": [


          {
            "type": "radiogroup",
            "name": "PrimaryInfoDetails",
            "title": "Did your current primary veterinarian give you useful information about LP/GOLPP?",
            "isRequired": true,
            "visibleIf": "{PrimaryVetInfo} = true",
            "choices": [
              {
                "value": "NO_INFO",
                "text": "No, I received little or no information."
              },
              {
                "value": "GENERAL_INFO",
                "text": "They gave me a general description of LP/GOLPP without going into detail."
              },
              {
                "value": "DETAILED_INFO",
                "text": "Explained LP/GOLPP in detail and told me about possible options, including surgery."
              },
              {
                "value": "DONT_KNOW",
                "text": "Don&lsquo;t know or can&lsquo;t remember."
              }
            ],
            "showOtherItem": true
          }
        ]
        },
        {
          "type": "panel",
          "name": "PrimarySurgeryPanel",
          "title": "",
          "elements": [

            {
              "type": "radiogroup",
              "name": "PrimarySurgery",
              "title": "Did your primary veterinarian make a recommendation about tieback or other LP/GOLPP surgeries for {CmpnName}'s LP/GOLPP?",
              "isRequired": true,
              "choices": [
                {
                  "value": "NO_RECOMMENDATION",
                  "text": "Made no recommendation"
                },
                {
                  "value": "ADVISED_FOR",
                  "text": "Encouraged me to talk to a surgeon"
                },
                {
                  "value": "ADVISED_AGAINST",
                  "text": "Advised against surgery"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "radiogroup",
              "name": "PrimarySurgeryPerception",
              "title": "Do you feel like your primary veterinarian's recommendation against surgery was due to {CmpnName}'s condition or to a generally negative perception of tieback surgery?",
              "isRequired": true,
              "visibleIf": "{PrimaryVetSurgery} = 'ADVISED_AGAINST'",
              "choices": [
                {
                  "value": "SPECIFIC_CONDITION",
                  "text": "{CmpnName}'s specific condition"
                },
                {
                  "value": "GENERAL_PERCEPTION",
                  "text": "General negative perception"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            }
          ]
        },
        {
          "type": "panel",
          "name": "PrimaryConfidencePanel",
          "title": "",
          "elements": [
            {
              "type": "radiogroup",
              "name": "PrimaryChangedVets",
              "title": "Did you ever change primary veterinarians because how they handled {CmpnName}'s LP/GOLPP symptoms?",
              "isRequired": true,
              "choices": [
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "ONCE",
                  "text": "Once"
                },
                {
                  "value": "MORE_THAN_ONCE",
                  "text": "More than once"
                }
              ]
            },
            
            {
              "type": "checkbox",
              "name": "PrimaryChangedVetsReason",
              "title": "Why did you change veterinarians after {CmpnName} started showing symptoms of LP/GOLPP?",
              "description": "Please check all that apply.",
              "isRequired": true,
              "visibleIf": "{PrimaryChangedVets} != 'NO'",
              "choices": [
                {
                  "value": "NOTHING_CAN_BE_DONE",
                  "text": "The previous vet said nothing could be done about {CmpnName}'s symptoms."
                },
                {
                  "value": "NO_KNOWLEDGE",
                  "text": "The previous vet couldn't give possible causes for {CmpnName}'s symptoms."
                },
                {
                  "value": "AGE_ONLY",
                  "text": "The previous vet said {CmpnName}'s symptoms were just due to age."
                },
                {
                  "value": "BAD_TESTS",
                  "text": "The previous vet ordered tests that I didn't think were relevant."
                },
                {
                  "value": "MISDIAGNOSED",
                  "text": "The previous vet misdiagnosed {CmpnName}'s symptoms."
                }
              ],
              "showOtherItem": true
            },
            {
              "type": "rating",
              "name": "PrimaryConfidence",
              "title": "How confident have you been in your current primary veterinarian's knowledge level regarding LP/GOLPP?",
              "description": "1 = not at all confident, 5 = very confident",
              "isRequired": true,
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" },
                { "value": "DONT_KNOW", "text": "Don't know" }
              ]
            }
          ]
        }
      ]
    }
  ]
}

            },
            {
              "type": "dropdown",
              "name": "ProcedureTiebackComplicationsCost",
              "title": "Approximate cost of post-operative complications, not including the cost of the surgery:",
              "description": "Please provide the pre-insurance cost, not the out-of-pocket cost.",
              "isRequired": true,
              "visibleIf": "{ProcedureTiebackComplications} = true",
              "choices": [
                {
                  "value": "NOT_SAY",
                  "text": "Prefer not to say"
                },
                {
                  "value": "UNDER_4000",
                  "text": "Under $1000"
                },
                {
                  "value": "1001_2000",
                  "text": "$1001-$2000"
                },
                {
                  "value": "2001_3000",
                  "text": "$2001-$3000"
                },
                {
                  "value": "3001_5000",
                  "text": "$3001-$5000"
                },
                {
                  "value": "OVER_5001",
                  "text": "Over $5001"
                }
              ],
              "showOtherItem": false
            }
          ]
        },

        {
          "type": "panel",
          "name": "ProcedureBveapPanel",

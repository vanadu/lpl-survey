{
  "name": "PROCEDURE-page",
  "elements": [
    {
      "type": "panel",
      "name": "ProcedureCard1Panel",
      "elements": [
        {
          "type": "html",
          "name": "ProcedureHeading",
          "html": "<h2>Veterinary-Medical Procedures</h2>"
        },
        {
          "type": "html",
          "name": "ProcedureText",
          "html": "<p>This section asks questions about any surgery or implant procedure {CmpnName} underwent to treat LP/GOLPP symptoms. This only includes surgeries or procedures that diriectly modify the structure of the larynx.</p>"
        },
        {
          "type": "boolean",
          "name": "ProcedureDidHave",
          "title": "Did {CmpnName} undergo a veterinary-medical procedure such as surgery or a stent implant for LP/GOLPP?",
          "isRequired": true,
          "labelTrue": "Yes",
          "labelFalse": "No",
          "swapOrder": true
        },
        {
          "type": "panel",
          "name": "ProcedureAgePanel",
          "title": "At about what age did {CmpnName} have the first procedure for LP/ GOLPP?",
          "description": "If you can't remember exactly, it's OK to guesstimate.",
          "visibleIf": "{ProcedureDidHave} = true",
          "elements": [
            {
              "type": "text",
              "inputType": "number",
              "name": "ProcedureAgeYears",
              "title": "Years",
              "isRequired": true,
              "min": "1",
              "max": "40",
                "validators": [
                {
                  "type": "numeric",
                  "minValue": 1,
                  "maxValue": 40,
                  "text": "Age must be between 1 and 40"
                }
              ]
            },
            {
              "type": "text",
              "inputType": "number",
              "name": "ProcedureAgeMonths",
              "title": "Months (number 0 - 11)",
              "isRequired": true,
              "min": 0,
              "max": 11,
              "validators": [
                {
                  "type": "numeric",
                  "minValue": 0,
                  "maxValue": 11,
                  "text": "Months must be between 0 and 11"
                }
              ]
            },
            {
              "type": "radiogroup",
              "name": "ProcedureScheduled",
              "title": "Was it a scheduled procedure or an emergency procedure due to an LP-induced breathing crisis?",
              "isRequired": true,
              "choices": [
                {
                  "value": "SCHEDULED",
                  "text": "Scheduled"
                },
                {
                  "value": "EMERGENCY",
                  "text": "Emergency"
                }
              ],
              "showOtherItem": false
            },
            {
            "type": "dropdown",
            "name": "ProcedureScheduledWait",
            "title": "How far in advance did you have to schedule the procedure?",
            "isRequired": true,
            "choices": [
              {
                "value": "LESS_THAN_TWO_WEEKS",
                "text": "Less than two weeks"
              },
              {
                "value": "TWO_TO_FOUR_WEEKS",
                "text": "Two to four weeks"
              },
              {
                "value": "FOUR_TO_EIGHT_WEEKS",
                "text": "Four to eight weeks"
              },
              {
                "value": "OVER_EIGHT_WEEKS",
                "text": "Move than eight weeks"
              }
            ],
            "showOtherItem": false
          }
          ]
        }
      ]
    },
    {
      "type": "panel",
      "name": "ProcedureCard2Panel",
      "elements": [

        {
          "type": "panel",
          "name": "ProcedureTypePanel",
          "elements": [
            {
            "type": "checkbox",
            "name": "ProcedureType",
            "title": "What kind of procedure or procedures did {CmpnName} have?",
            "description": "Please check all that apply.",
            "isRequired": true,
            "visibleIf": "{ProcedureDidHave} = true",
            "choices": [
              {
                "value": "TIEBACK",
                "text": "Tieback (Unilateral Arytenoid Lateralization)"
              },
              {
                "value": "BVEAP",
                "text": "BVEAP (Bilateral Vocal Fold Excision & Arytenoid Pexy)"
              },
              {
                "value": "STENT",
                "text": "Laryngeal stent"
              },
              { "value": "ARYTENOIDECTOMY",
                "text": "Partial arytenoidectomy"  
              },
              { "value": "VENTRILOCORDECTOMY",
                "text": "Ventrilocordectomy"  
              }
            ],
            "showOtherItem": true
            }
          ]
        },
        {
          "type": "panel",
          "name": "ProcedureTiebackPanel",
          "title": "Questions about tieback (Unilateral Arytenoid Lateralization) surgery",
          "visibleIf": "{ProcedureDidHave} = true && {ProcedureType} contains 'TIEBACK'",
          "elements": [

            {
              "type": "boolean",
              "name": "ProcedureTiebackEmergency",
              "title": "Was emergency tieback performed on {CmpnName} after a life-threatening breathing emergency?",
              "labelTrue": "Yes",
              "labelFalse": "No",
              "swapOrder": true,
              "isRequired": true
            },
            {
              "type": "radiogroup",
              "name": "ProcedureTiebackInfection",
              "title": "Did {CmpnName} have any unexpected issues with infection or swelling at the incision site?",
              "isRequired": true,
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "radiogroup",
              "name": "ProcedureTiebackSuturesFail",
              "title": "Did the sutures ever fail, causing a return of {CmpnName} LP symptoms?",
              "isRequired": true,
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            },            
            {
              "type": "radiogroup",
              "name": "ProcedureTiebackSuturesFailRepeat",
              "title": "Did the sutures ever fail, causing a return of {CmpnName} LP symptoms?",
              "isRequired": true,
              "visibleIf": "{ProcedureTiebackSuturesFail} = 'YES'",
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "radiogroup",
              "name": "ProcedureTiebackSuturesFailRepeat",
              "title": "Did the sutures ever fail, causing a return of {CmpnName} LP symptoms?",
              "isRequired": true,
              "visibleIf": "{ProcedureTiebackSuturesFail} = 'YES'",
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"

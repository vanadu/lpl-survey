                },
                {
                  "value": "UNDER_2500",
                  "text": "Under $2500"
                },
                {
                  "value": "2501_4000",
                  "text": "$2501-$4000"
                },
                {
                  "value": "4001_5500",
                  "text": "$4000-$5500"
                },
                {
                  "value": "5500_7000",
                  "text": "$5500-$7000"
                },
                {
                  "value": "OVER_7000",
                  "text": "Over $7000"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "dropdown",
              "name": "ProcedureTiebackMultipleCost",
              "title": "Approximate total cost of surgeries (not including post-op complications):",
              "description": "Please provide the pre-insurance cost, not the out-of-pocket cost.",
              "isRequired": true,
              "visibleIf": "{ProcedureTiebackCount} = 'MORE_THAN_ONCE'",
              "choices": [
                {
                  "value": "NOT_SAY",
                  "text": "Prefer not to say"
                },
                {
                  "value": "UNDER_4000",
                  "text": "Under $4000"
                },
                {
                  "value": "4001_5500",
                  "text": "$4001-$5500"
                },
                {
                  "value": "5501_7000",

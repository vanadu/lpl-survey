                }
              ],
              "showOtherItem": false
            }

          ]
        },

        {
          "type": "panel",
          "name": "ProcedureStentPanel",
          "visibleIf": "{ProcedureDidHave} = true && {ProcedureType} contains 'STENT'",
          "elements": [

            {
              "type": "dropdown",
              "name": "ProcedureStentType",
              "title": "What type of stent implant did {CmpnName} receive?",
              "isRequired": true,
              "choices": [
                {
                  "value": "SILICONE",
                  "text": "Silicone"
                },
                {
                  "value": "DEXSTENT",
                  "text": "Dextronix DexStent LE Nitinol wire"
                },
                {
                  "value": "NITINOL_MESH",
                  "text": "Nitinol mesh"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": true
            },
            {
              "type": "panel",
              "name": "ProcedureDexstentPanel",
              "visibleIf": "{ProcedureStentType} contains 'DEXSTENT'",
              "elements": [
                {
                  "type": "html",
                  "name": "ProcedureDexstentText",
                  "html": "<b>IMPORTANT</b>: The Dextronix DexStent LE Nitinol wire stent device has been discontinued by the manufacturer. Report parties involved in the sale or use of this device to your local veterinary regulatory agency."
                }
              ]
            },
            {
              "type": "boolean",
              "name": "ProcedureStentDidMigrate",
              "title": "Did {CmpnName} eject or 'cough out' the stent, or did it migrate out of position?",
              "isRequired": true,
              "visibleIf": "{ProcedureStentType} = 'SILICONE' || {ProcedureStentType} = 'NITINOL_MESH'",
              "labelTrue": "Yes",
              "labelFalse": "No",
              "swapOrder": true
            },

            {
              "type": "boolean",
              "name": "ProcedureStentReplaced",
              "title": "Was it replaced with a new stent of a different size?",
              "isRequired": true,
              "visibleIf": "{ProcedureStentDidMigrate} = true && {ProcedureStentType} != 'DONT_KNOW' && {ProcedureStentType} != 'DEXSTENT' && {ProcedureStentType} != 'Other'",
              "labelTrue": "Yes",
              "labelFalse": "No",
              "swapOrder": true
            },
            {
              "type": "radiogroup",
              "name": "ProcedureStentHalitosis",
              "title": "Did {CmpnName} have halitosis after the stent implant?",
              "isRequired": true,
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "rating",
              "name": "ProcedureStentHalitosisRating",
              "title": "How bad was {CmpnName}’s halitosis after the stent implant?",
              "description": "1 = not bad, 5 = very bad",
              "isRequired": true,
              "visibleIf": "{ProcedureStentHalitosis} = 'YES'",
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" },
                { "value": "DONT_KNOW", "text": "Don't know" }
              ]
            },
            {
              "type": "radiogroup",
              "name": "ProcedureStentInfected",
              "title": "Did the tissue around the stent ever become infected?",
              "isRequired": true,
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "radiogroup",
              "name": "ProcedureStentInfectedHandling",
              "title": "How was the infection handled?",
              "isRequired": true,
              "visibleIf": "{ProcedureStentInfected} = 'YES'",
              "choices": [
                {
                  "value": "REMOVED_PERMANENTLY",
                  "text": "The stent was permanently removed."
                },
                {
                  "value": "REMOVED_AND_REPLACED",
                  "text": "The stent was removed, disinfected, and replaced."
                },
                {
                  "value": "NO_ACTION",
                  "text": "No action was taken."
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know."
                }

              ],
              "showOtherItem": false
            },
            {
              "type": "radiogroup",
              "name": "ProcedureStentThroatclear",
              "title": "Did {CmpnName} frequently cough or throat-clear after the stent procedure?",
              "isRequired": true,
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "radiogroup",
              "name": "ProcedureStentThroatclearImproved",
              "title": "Did {CmpnName}'s coughing or throat-clearing improve over time?",
              "isRequired": true,
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            },

            {
              "type": "dropdown",
              "name": "ProcedureStentCostOnce",
              "title": "Approximate cost of stent implant procedure, not including complications:",
              "description": "Please provide the pre-insurance cost, not the out-of-pocket cost.",
              "isRequired": true,
              "visibleIf": "{ProcedureStentDidMigrate} = false || {ProcedureStentReplaced} = false",
              "choices": [
                {
                  "value": "NOT_SAY",
                  "text": "Prefer not to say"
                },
                {
                  "value": "UNDER_1500",
                  "text": "Under $1500"
                },
                {
                  "value": "1501_2500",
                  "text": "$1501-$2000"
                },
                {
                  "value": "2001_3000",
                  "text": "$2001-$3000"
                },
                {
                  "value": "3001_4000",
                  "text": "$3001-$4000"
                },
                {
                  "value": "OVER_4000",
                  "text": "Over $4000"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "dropdown",
              "name": "ProcedureStentCostRepeat",
              "title": "Approximate cost of the stent procedures, not including complications:",
              "description": "Please provide the pre-insurance cost, not the out-of-pocket cost.",
              "isRequired": true,
              "visibleIf": "{ProcedureStentDidMigrate} = true && {ProcedureStentReplaced} = true",
              "choices": [
                {
                  "value": "NOT_SAY",
                  "text": "Prefer not to say"
                },
                {
                  "value": "UNDER_1500",
                  "text": "Under $1500"
                },
                {
                  "value": "1501_2500",
                  "text": "$1501-$2000"
                },
                {
                  "value": "2001_3000",
                  "text": "$2001-$3000"
                },
                {
                  "value": "3001_4000",
                  "text": "$5500-$7000"
                },
                {
                  "value": "OVER_4000",
                  "text": "Over $4000"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "boolean",
              "name": "ProcedureStentComplications",
              "title": "Were there post-operative complications that required overnight inpatient care for {CmpnName}?",
              "visibleIf": "{ProcedureStentType} notempty",
              "isRequired": true,
              "labelTrue": "Yes",
              "labelFalse": "No",
              "swapOrder": true
            }
          ]
        },

        {
          "type": "panel",
          "name": "ProcedureArytenoidectomyPanel",
          "title": "Questions about partial arytenoidectomy surgery",
          "description": "Partial arytenoidectomy is the surgical removal of a section of one of the arytenoid (laryngeal) cartilages.",

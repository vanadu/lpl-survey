{
  "name": "TREATMENT_FACTORS-page",
  "elements": [
    {
      "type": "panel",
      "name": "TreatmentFactorsCard1Panel",
      "elements": [
        {
          "type": "html",
          "name": "TreatmentFactorsHeading",
          "html": "<h2>Factors that have influenced your LP/GOLPP decisions</h2>"
        },
        {
          "type": "html",
          "name": "TreatmentFactorsText",
          "html": "<p>The LP/GOLPP journey requires making difficult decisions based on personal, financial, and family considerations. Please rate the factors that played a role in your LP/GOLPP decisions. </p>"
        },
        {
          "type": "panel",
          "name": "TreatmentFactorsDecisionPanel",
          "visibleIf": "{TreatmentStatusDidHave} = false && {LifeStatus} = false",
          "elements": [
            {
              "type": "dropdown",
              "name": "TreatmentFactorsDecision",
              "title": "Have you made a decision about whether or not to pursue LP surgery such as tieback for {CmpnName}?",
              "isRequired": true,
              "choices": [
                {
                  "value": "WILL_PURSUE",
                  "text": "We will pursue LP surgery such as tieback."
                },
                {
                  "value": "WILL_NOT_PURSUE",
                  "text": "We've decided not to pursue LP surgery."
                },
                {
                  "value": "UNDECIDED",
                  "text": "We haven't decided yet."
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "dropdown",
              "name": "TreatmentFactorsDecisionStent",
              "title": "If a veterinarian were to offer a stent implant for LP/GOLPP in your area, would you explore that as a surgery alternative?",
              "isRequired": true,
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes, we would consider a stent implant."
                },
                {
                  "value": "NO",
                  "text": "No, we would not consider a stent implant."
                },
                {
                  "value": "NOT_INFORMED",
                  "text": "We need more information."
                }
              ],
              "showOtherItem": false
            }
          ]
        }
      ]
    },

    {
      "type": "panel",
      "name": "TreatmentFactorsCard2Panel",
      "elements": [
        {
          "type": "panel",
          "name": "TreatmentFactorsCostPanel",
          "title": "How have financial considerations factored into your LP/GOLPP decisions?", 
          "elements": [
            {
              "type": "rating",
              "name": "TreatmentFactorsCost",
              "title": "Cost of surgical/stent procedure:",
              "description": "1 = not a factor, 5 = deciding factor",
              "isRequired": true,
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" }
              ]
            },
            {
              "type": "rating",
              "name": "TreatmentFactorsCostComplications",
              "title": "Added cost of possible post-op complications such as aspiration pneumonia:",
              "description": "1 = not a factor, 5 = deciding factor",
              "isRequired": true,
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" }
              ]
            }
          ]
        },

        {
          "type": "panel",
          "name": "TreatmentFactorsStagePanel",
          "title": "Which aspects of {CmpnName}'s LP/GOLPP have factored into your decisions?",
          "elements": [
          {
            "type": "rating",
            "name": "TreatmentFactorsBreathingCrisisFear",
            "title": "Fear of a breathing crisis or emergency:",
            "description": "1 = not a factor, 5 = deciding factor",
            "isRequired": true,
            "rateValues": [
              { "value": 1, "text": "1" },
              { "value": 2, "text": "2" },
              { "value": 3, "text": "3" },
              { "value": 4, "text": "4" },
              { "value": 5, "text": "5" }
            ]
          },

          {
            "type": "rating",
            "name": "TreatmentFactorsStageNeuropathy",
            "title": "{CmpnName}'s hind-end weakness and polyneuropathy:",
            "description": "1 = not a factor, 5 = deciding factor",
            "isRequired": true,
            "rateValues": [
              { "value": 1, "text": "1" },
              { "value": 2, "text": "2" },
              { "value": 3, "text": "3" },
              { "value": 4, "text": "4" },
              { "value": 5, "text": "5" }
              ]
            }
          ]
        },

        {
          "type": "panel",
          "name": "TreatmentFactorsSurgeryRisksPanel",
          "title": "Which risk factors of surgery have factored into your decision?",
          "elements": [
            {
              "type": "rating",
              "name": "TreatmentFactorsAnesthesia",
              "title": "Extended anesthesia:",
              "description": "1 = not a factor, 5 = deciding factor",
              "isRequired": true,
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" }
              ]
            },
            {
              "type": "rating",
              "name": "TreatmentFactorsInpatientComplications",
              "title": "Risk of direct inpatient complications of surgery:",
              "description": "1 = not a factor, 5 = deciding factor",
              "isRequired": true,
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" }
              ]
            },
            {
              "type": "rating",
              "name": "TreatmentFactorsLongTermComplications",
              "title": "Risks of long-term complications such as aspiration pneumonia, suture failure, or infection:",
              "description": "1 = not a factor, 5 = deciding factor",
              "isRequired": true,
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" }
              ]
            }

          ]
        },

        {
          "type": "panel",
          "name": "TreatmentFactorsGeneralPanel",
          "title": "How have {CmpnName}'s age and general health considerations factored into your decision?",
          "elements": [
            {
              "type": "rating",
              "name": "TreatmentFactorsAge",
              "title": "{CmpnName}'s age:",
              "description": "1 = not a factor, 5 = deciding factor",
              "isRequired": true,
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" }
              ]
            },
            {
              "type": "rating",
              "name": "TreatmentFactorsGeneralHealth",
              "title": "{CmpnName}'s overall health and prospects for quality of life:",
              "description": "1 = not a factor, 5 = deciding factor",
              "isRequired": true,
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" }
              ]
            },
            {
              "type": "rating",
              "name": "TreatmentFactorsCoexisting",
              "title": "{CmpnName}'s preexisting conditions other than LP/GOLPP:",
              "description": "1 = not a factor, 5 = deciding factor",
              "isRequired": true,
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" }
              ]
            }
          ]
        },

        {
          "type": "panel",
          "name": "TreatmentFactorsCircumstancesPanel",
          "title": "How have your personal circumstances factored into your decision?",
          "elements": [
            {
              "type": "rating",
              "name": "TreatmentFactorsCircumstancesAccess",
              "title": "Distance to or access to a qualified specialist:",
              "description": "1 = not a factor, 5 = deciding factor",
              "isRequired": true,
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" }
              ]
            },

            {
              "type": "rating",
              "name": "TreatmentFactorsCircumstancesCare",
              "title": "Ability to provide adequate post-operative care:",
              "description": "1 = not a factor, 5 = deciding factor",
              "isRequired": true,
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" }
              ]
            }
          ]
        },

        {
          "type": "panel",
          "name": "TreatmentFactorsOtherPanel",
          "title": "What other considerations, if any, have factored into your decision?",
          "elements": [
            {
              "type": "text",
              "name": "TreatmentFactorsOther",
              "title": "Other considerations:",
              "description": "Maximum 250 charactsers.",
              "isRequired": false
            }
          ]
        }

      ]
    }
  ]
}
{
  "name": "CONCLUSION-page",
  "elements": [

    {
      "type": "panel",
      "name": "ConclusionCard1Panel",
      "elements": [
        {
          "type": "html",
          "name": "ConclusionHeading",
          "html": "<h2>Conclusion</h2>"
        },
        {
          "type": "html",
          "name": "Conclusion",
          "html": "<p>The last section of this survey references your earlier responses to determine how {CmpnName}'s LP/GOLPP developed over time and what factors may have played a role in the LP/GOLPP progression. </p>"
        },
        {
          "type": "panel",
          "name": "ConclusionsPanelLifeStatusTrue",
          "visibleIf": "{LifeStatus} = true",
          "elements": [

            {
              "type": "html",
              "name": "ConclusionsPanelLifeStatusTrueText",
              "html": "<p><b>NOTE: </b>These questions ask about the last station of {CmpnName}'s LP/GOLPP journey before {cvGenderSubjectPronoun} crossed over the Rainbow Bridge. If it's too painful to revisit this stage of {CmpnName}'s life, it might be best to discontinue the survey and return to it later. </p>"
            }
          ]
        },
        {
          "type": "panel",
          "name": "ConclusionsPanelLifeStatusFalse",
          "visibleIf": "{LifeStatus} = false",
          "elements": [
            {
              "type": "html",
              "name": "ConclusionsPanelLifeStatusFalseText",
              "html": "<p><b>IMPORTANT:</b> Please answer the questions about {CmpnName} in {cvGenderObjectPronoun} current state of health.</p>"
            }
          ]
        },
        {
        "type": "panel",
        "name": "ConclusionDetailsPanel",
        "elements": [
          {
            "type": "radiogroup",
            "name": "ConclusionLifestyleChanges",
            "title": "Did you make any changes to {CmpnName}'s lifestyle or routine due to {cvGenderObjectPronoun} LP/GOLPP?",
            "isRequired": true,
            "choices": [
              {
                "value": "YES",
                "text": "Yes"
              },
              {
                "value": "NO",
                "text": "No"
              },
              {
                "value": "DONT_KNOW",
                "text": "Don't know"
              }
            ],
            "showOtherItem": false
          },
          {
            "type": "checkbox",
            "name": "ConclusionLifestyleChangesDetails",
            "title": "Please describe any lifestyle restrictions or changes you made for {CmpnName} due to {cvGenderObjectPronoun} LP/GOLPP:",
            "isRequired": true,
            "visibleIf": "{ConclusionLifestyleChanges} = 'YES'",
            "choices": [

              {
                "value": "EXERCISE",
                "text": "Exercise restrictions"
              },
              {
                "value": "FEEDING",
                "text": "Changes in food and/or feeding frequency"
              },
              {
                "value": "TRAVEL",
                "text": "Travel restrictions"
              },
              {
                "value": "SWIMMING",
                "text": "Restricted swimming and access to water"
              },
              {
                "value": "STAIRS",
                "text": "Restrictred access to stairs"
              },
              {
                "value": "INTERACTION",
                "text": "Limitations on interaction with people or other animals"
              }
            ],
            "showOtherItem": true
          },
          {
            "type": "checkbox",
            "name": "ConclusionGeneralCondition",
            "title": "How has {CmpnName}'s condition changed since the first LP/GOLPP symptoms appeared?",
            "isRequired": true,
            "choices": [
              {
                "value": "NO_CHANGE",
                "text": "No significant change"
              },
              {
                "value": "KNUCKLING",
                "text": "Knuckling"
              },
              {
                "value": "FALLING",
                "text": "Frequent falling while walking"
              },
              {
                "value": "GET_UP",
                "text": "Difficulty getting up or standing"
              },
              {
                "value": "URINARY",
                "text": "Urinary incontinence"
              },
              {
                "value": "FECAL",
                "text": "Fecal incontinence"
              },
              {
                "value": "COGNITIVE",
                "text": "Cognitive or behavioral changes"
              },
              {
                "value": "ANXIETY",
                "text": "Significant increase in anxiety"
              }
            ],
            "showOtherItem": false
          },
          {
            "type": "rating",
            "name": "ConclusionQOL",
            "title": "How would you rate {CmpnName}'s quality of life at this stage?",
            "description": "1 = very poor, 3 = fair, 5 = very good",
            "isRequired": true,
            "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" },
                { "value": "DONT_KNOW", "text": "Don't know" }
              ]
            }
          ]
        },
        {
          "type": "panel",
          "name": "ConclusionOtherConditionsPanel",
          "elements": [
            {
              "type": "boolean",
              "name": "ConclusionOtherConditionsNew",
              "title": "Did {CmpnName} develop any new conditions during {cvGenderObjectPronoun} LP/GOLPP journey that {cvGenderSubjectPronoun} didn't have before?",
              "labelTrue": "Yes",
              "labelFalse": "No",
              "swapOrder": true,
              "isRequired": true
            },
            {
              "type": "checkbox",
              "name": "ConclusionOtherConditions",
              "title": "What other conditions did {CmpnName} develop during {cvGenderObjectPronoun} LP/GOLPP journey?",
              "description": "The selections you made about the beginning of {CmpnName}'s LP/GOLPP journey are preselected.",
              "visibleIf": "{ConclusionOtherConditionsNew} = true",
              "isRequired": true,
              "choices": [
                {
                  "value": "GERD",
                  "text": "Acid reflux (GERD)"
                },
                {
                  "value": "ME",
                  "text": "Megaesophagus"
                },
                {
                  "value": "DM",
                  "text": "Degenerative Myelopathy"
                },
                {
                  "value": "ARTHRITIS",
                  "text": "Arthritis"
                },
                {
                  "value": "CUSHINGS",
                  "text": "Cushings"
                },
                {
                  "value": "CT",
                  "text": "Collapsing Trachea"
                },
                {
                  "value": "HYPOTHYROID",
                  "text": "Hypothyroidism"
                },
                {
                  "value": "HEMANGIOSARCOMA",
                  "text": "Hemangiosarcoma"
                },
                {
                  "value": "CANCER",
                  "text": "Cancer or malignant tumor"
                }
              ],
              "choicesOrder": "none",
              "otherText": "Other",
              "showOtherItem": true
            },
            {
              "type": "rating",
              "name": "ConclusionUserLifestyle",
              "title": "Has {CmpnName}'s LP/GOLPP resulted in a substantial change to your lifestyle?",
              "description": "1 = no, not at all, 5 = yes, very much",
              "isRequired": true,
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" },
                { "value": "DONT_KNOW", "text": "Don't know" }
              ]
            },
            {
              "type": "rating",
              "name": "ConclusionUserDistress",
              "title": "Has {CmpnName}'s LP/GOLPP caused you or anyone in your family significant emotional distress or anxiety?",
              "description": "1 = no, not at all, 5 = yes, very much",
              "isRequired": true,
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" },
                { "value": "DONT_KNOW", "text": "Don't know" }
              ]
            }
          ]
        }
      ]
    },

    {
      "type": "panel",
      "name": "ConclusionCard2Panel",
      "elements": [

        {
          "type": "panel",
          "name": "ConclusionCauseOfDeathPanel",
          "visibleIf": "{LifeStatus} = true",
          "elements": [
            {
              "type": "html",
              "name": "ConclusionCauseOfDeathHeading",
              "html": "Euthanasia is a humane way to say goodbye when a beloved animal companion has reached end-of-life. This question asks about the primary cause of {CmpnName}'s passing, not whether humane euthanasia was chosen to help them cross over."
            },
            {
                "type": "radiogroup",
                "name": "ConclusionCauseOfDeath",
                "title": "What was the ultimate reason why {CmpnName} crossed over the Rainbow Bridge?",
                "isRequired": true,
                "choices": [
                  {
                    "value": "COMPLICATIONS",
                    "text": "Post-op complications of LP-related surgical procedure"
                  },
                  {
                    "value": "BREATHING_CRISIS",
                    "text": "Fatal LP-related breathing crisis"
                  },
                  {
                    "value": "ASPIRATION",
                    "text": "Aspiration pneumonia"
                  },
                  {
                    "value": "QOL_POLYNEUROPATHY",
                    "text": "Quality of life due to polyneuropathy or hind-end weakness"
                  },
                  {
                    "value": "QOL_BREATHING",
                    "text": "Quality of life due to LP-related breathing problems"
                  },
                  {
                    "value": "QOL_AGING",
                    "text": "Poor quality of life due to aging"
                  },
                  {
                    "value": "STOPPED_EATING",
                    "text": "Stopped eating"
                  }
                ],
                "showOtherItem": true,
                "otherText": "Other cause unrelated to GOLPP (please explain)"
            }
          ]
        },

        {
          "type": "panel",
          "name": "ConclusionOtherPathPanel",
          "title": "These questions are speculative. If you were to have another dog with LP, would you choose a different path along their LP/GOLPP journey?",
          "elements": [
            {
              "type": "radiogroup",
              "name": "ConclusionOtherPath",
              "title": "Would you do anything differently than with {CmpnName}?",
              "isRequired": true,
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes, I would do things differently."
                },
                {
                  "value": "NO",
                  "text": "No, I would choose the same course of action."
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know or prefer not to say."
                }
              ],
              "showOtherItem": false
            },
            
            {
              "type": "radiogroup",
              "name": "ConclusionOtherPathDetails",
              "title": "What do you think you would do differently?",
              "isRequired": true,
              "visibleIf": "{ConclusionOtherPath} = 'YES' && {ProcedureDidHave} = true",
              "choices": [
                {
                  "value": "NO_SURGERY",
                  "text": "I would not pursue surgery for another LP/GOLPP dog."
                },
                {
                  "value": "DIFFERENT_PROCEDURE",
                  "text": "I would pursue a different surgery or a laryngeal stent rather than the one {CmpnName} had."
                },
                {
                  "value": "DIFFERENT_VET",
                  "text": "If would find a different surgeon to do the same procedure {CmpnName} had."
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": true,
              "otherText": "Other option"
            },

            {
              "type": "radiogroup",
              "name": "ConclusionOtherPathTimeframe",
              "title": "If you had another LP/GOLPP dog, would you do the surgical/stent procedure earlier or later?",
              "isRequired": true,
              "visibleIf": "{ProcedureDidHave} = true && {ConclusionOtherPath} = 'YES'",
              "choices": [
                {
                  "value": "EARLIER",
                  "text": "Earlier"
                },
                {
                  "value": "LATER",
                  "text": "Later"
                },
                {
                  "value": "SAME",
                  "text": "At about the same time frame"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "checkbox",
              "name": "ConclusionOtherPathNoTreatment",
              "title": "If you were to have another LP/GOLPP companion, what if anything would you differently?",
              "isRequired": true,
              "visibleIf": "{ConclusionOtherPath} = 'YES' && {ProcedureDidHave} = false",
              "choices": [
                {
                  "value": "NO_TREATMENT_SAME",
                  "text": "I would pursue the same course of action as with {CmpnName}"
                },
                {
                  "value": "NO_TREATMENT_PROCEDURE",
                  "text": "I would pursue tieback, laryngeal stent, or other surgical procedure"
                },
                {
                  "value": "NO_TREATMENT_THERAPY",
                  "text": "I would pursue acupuncture, physical therapy, or other non-traditional approaches"
                }
              ],
              "showOtherItem": false
            },

            {
              "type": "comment",
              "name": "ConclusionDifferentChoices",
              "title": "Please add any brief comments about your and {CmpnName}'s LP/GOLPP journey (optional, maximum 250 characters).",
              "isRequired": false
            },
            {
              "type": "panel",
              "name": "ConclusionThanksPanel",
              "elements": [
                {
                  "type": "html",
                  "name": "ConclusionThanksHead",
                  "html": "<div class='conclusion-thanks-head-container'><h2 class='conclusion-thanks-title-heading'>LP/GOLPP Survey 2026</h2><img src='./img-lpl-logo.png' class='survey-version-logo' alt='LarParLife.org logo' width='500' height='600'><h3 class='conclusion-thanks-title-subheading'>Thank You For Taking The Survey!</h3><p class='conclusion-thanks-note-mobile'>Please select the checkbox to complete and submit.</p><p class='conclusion-thanks-note'>Please click the <b>Complete</b> button to submit your responses.</p></div>"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
                {
                  "value": "ANTIHISTAMINE",
                  "text": "Benadryl or other antihistamine"
                },                            
                {
                  "value": "CERENIA",
                  "text": "Cerenia (maripotant citrate)"
                },
                {
                  "value": "MELOXICAM",
                  "text": "Meloxicam"
                },
                {
                  "value": "ACEPROMINE",
                  "text": "Acepromazine (Atravet, ACP, Acepromine)"

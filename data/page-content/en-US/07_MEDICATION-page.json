              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "checkbox",
              "name": "MedicationPrescriptionType",
              "title": "What prescription medications if any did your primary veterinarian prescribe or recommend for {CmpnName}'s LP/GOLPP symptoms?",
              "description": "Please also include discontinued medications.",
              "isRequired": true,
              "visibleIf": "{MedicationPrescription} = 'YES'",
              "choices": [
                {
                  "value": "DOXEPIN",
                  "text": "Doxepin"
                },
                {
                  "value": "TRAZODONE",
                  "text": "Trazodone"
                },
                {
                  "value": "GABAPENTIN",
                  "text": "Gabapentin"
                },
                {
                  "value": "GALLIPRANT",

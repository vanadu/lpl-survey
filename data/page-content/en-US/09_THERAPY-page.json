{
  "name": "THERAPY-page",
  "elements": [

    {
      "type": "panel",
      "name": "TherapyCard1Panel",
      "elements": [


        {
          "type": "html",
          "name": "TherapyHeading",
          "html": "<h2>Therapy for LP/GOLPP</h2>"
        },
        {
          "type": "html",
          "name": "TherapyText",
          "html": "<p>This section asks about non-traditional treatments or therapy {CmpnName} has had for LP/GOLPP.</p>"
        },

        {
          "type": "panel",
          "name": "TherapyTypePanel",
          "elements": [
            {
              "type": "radiogroup",
              "name": "TherapyDidHave",
              "title": "Did {CmpnName} receive acupuncture or other therapies to help with LP/GOLPP symptoms?",
              "isRequired": true,
              
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            },
            {
              "type": "checkbox",
              "name": "TherapyType",
              "title": "What therapies or treatments did {CmpnName} receive?",
              "isRequired": true,
              "visibleIf": "{TherapyDidHave} = 'YES'",
              "choices": [
                {
                  "value": "ACUPUNCTURE",
                  "text": "Acupuncture"
                },
                {
                  "value": "THERAPY",
                  "text": "Physical or hydro therapy"
                },
                {
                  "value": "LLLT",
                  "text": "Cold laser or red light therapy"
                },
                {
                  "value": "CHIRO",
                  "text": "Chiropractic"
                }
              ],
              "showOtherItem": true
            },

            {
              "type": "rating",
              "name": "TherapyAcupunctureRatingBreathing",
              "title": "Please rate the effect of acupuncture on {CmpnName}'s breathing:",
              "description": "1 = very negative, 3 = no effect,  5 = very positive",
              "isRequired": true,
              "visibleIf": "{TherapyDidHave} = 'YES' && {TherapyType} contains 'ACUPUNCTURE'",
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" },
                { "value": "DONT_KNOW", "text": "Don't know" }
              ]
            },
            {
              "type": "rating",
              "name": "TherapyAcupunctureRatingMobility",
              "title": "Please rate the effect of acupuncture on {CmpnName}'s mobility or behavior:",
              "description": "1 = very negative, 3 = no effect,  5 = very positive",
              "isRequired": true,
              "visibleIf": "{TherapyDidHave} = 'YES' && {TherapyType} contains 'ACUPUNCTURE'",
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" },
                { "value": "DONT_KNOW", "text": "Don't know" }
              ]
            },
            {
              "type": "rating",
              "name": "TherapyTherapyRatingBreathing",
              "title": "Please rate the effect of physical or hydro therapy on {CmpnName}'s breathing:",
              "description": "1 = very negative, 3 = no effect,  5 = very positive",
              "isRequired": true,
              "visibleIf": "{TherapyDidHave} = 'YES' && {TherapyType} contains 'THERAPY'",
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" },
                { "value": "DONT_KNOW", "text": "Don't know" }
              ]
            },
            {
              "type": "rating",
              "name": "TherapyTherapyRatingMobility",
              "title": "Please rate the effect of physical or hydro therapy on {CmpnName}'s mobility or behavior:",
              "description": "1 = very negative, 3 = no effect,  5 = very positive",
              "isRequired": true,
              "visibleIf": "{TherapyDidHave} = 'YES' && {TherapyType} contains 'THERAPY'",
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" },
                { "value": "DONT_KNOW", "text": "Don't know" }
              ]
            },
            {
              "type": "rating",
              "name": "TherapyColdLaserRatingBreathing",
              "title": "How effective was cold laser or red light therapy on {CmpnName}'s breathing:",
              "description": "1 = very negative, 3 = no effect,  5 = very positive",
              "isRequired": true,
              "visibleIf": "{TherapyDidHave} = 'YES' && {TherapyType} contains 'LLLT'",
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" },
                { "value": "DONT_KNOW", "text": "Don't know" }
              ]
            },
            {
              "type": "rating",
              "name": "TherapyColdLaserRatingMobility",
              "title": "Please rate the effect of cold laser or red light therapy on {CmpnName}'s mobility or behavior:",
              "description": "1 = very negative, 3 = no effect,  5 = very positive",
              "isRequired": true,
              "visibleIf": "{TherapyDidHave} = 'YES' && {TherapyType} contains 'LLLT'",
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" },
                { "value": "DONT_KNOW", "text": "Don't know" }
              ]
            },
            {
              "type": "rating",
              "name": "TherapyChiroRatingBreathing",
              "title": "Please rate the effect of chiropractic on {CmpnName}'s breathing on {CmpnName}'s mobility or behavior:",
              "description": "1 = very negative, 3 = no effect,  5 = very positive",
              "isRequired": true,
              "visibleIf": "{TherapyDidHave} = 'YES' && {TherapyType} contains 'CHIRO'",
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" },
                { "value": "DONT_KNOW", "text": "Don't know" }
              ]
            },
            {
              "type": "rating",
              "name": "TherapyChiroRatingMobility",
              "title": "Please rate the effect of chiropractic on {CmpnName}'s mobility or behavior:",
              "description": "1 = very negative, 3 = no effect,  5 = very positive",
              "isRequired": true,
              "visibleIf": "{TherapyDidHave} = 'YES' && {TherapyType} contains 'CHIRO'",
              "rateValues": [
                { "value": 1, "text": "1" },
                { "value": 2, "text": "2" },
                { "value": 3, "text": "3" },
                { "value": 4, "text": "4" },
                { "value": 5, "text": "5" },
                { "value": "DONT_KNOW", "text": "Don't know" }
              ]
            },

            {
              "type": "dropdown",
              "name": "TherapyCost",
              "title": "Average monthly cost of {CmpnName}'s acupuncture or other therapies:",
              "description": "If you don't know exactly, it's OK to guesstimate.",
              "isRequired": true,
              "visibleIf": "{TherapyType} notempty",
              "choices": [
                {
                  "value": "UNDER_100",
                  "text": "Under $100"
                },
                {
                  "value": "101_150",
                  "text": "$101-150"
                },
                {
                  "value": "151_250",
                  "text": "$151-$250"
                },
                {
                  "value": "OVER_250",
                  "text": "Over $250"
                }
              ],
              "showOtherItem": true,
              "showNoneItem": true,
              "required": true
            }

          ]
        }
      ]
    }
  ]
}
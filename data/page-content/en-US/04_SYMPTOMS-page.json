{
  "name": "SYMPTOMS-page",
  "elements": [
    {
      "type": "panel",
      "name": "SymptomsCard1Panel",
      "elements": [
        {
          "type": "html",
          "name": "SymptomsHeading",
          "html": "<h2>{CmpnName}'s Early LP/GOLPP Symptoms</h2>"
        },
        {
          "type": "html",
          "name": "SymptomsText",
          "html": "<p>This section asks questions about the early phase of your LP/GOLPP journey and how you came to believe {CmpnName} might have it.</p>"
        },

        {
          "type": "panel",
          "name": "SymptomsDetailsPanel",
          "elements": [
          {
            "type": "panel",
            "name": "SymptomsAgePanel",
            "title": "At about what age did {CmpnName} start showing symptoms of LP/GOLPP?",
            "elements": [
                {
                  "type": "panel",
                  "name": "SymptomsAgeDetailsPanel",
                  "description": "Please enter years and months",
                  "elements": [
                    {
                      "type": "text",
                      "inputType": "number",
                      "name": "SymptomsAgeYears",
                      "title": "Years",
                      "isRequired": true,
                      "min": "1",
                      "max": "40",
                        "validators": [
                        {
                          "type": "numeric",
                          "minValue": 1,
                          "maxValue": 40,
                          "text": "Age must be between 1 and 40"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "inputType": "number",
                      "name": "SymptomsAgeMonths",
                      "title": "Months (0 - 11)",
                      "isRequired": true,
                      "min": 0,
                      "max": 11,
                      "validators": [
                        {
                          "type": "numeric",
                          "minValue": 0,
                          "maxValue": 11,
                          "text": "Months must be between 0 and 11"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "checkbox",
              "name": "SymptomsType",
              "title": "What symptoms did {CmpnName} have at that time?",
              "choices": [
                {
                  "value": "STRIDOR",
                  "text": "Noisy, raspy or labored breathing"
                },
                {
                  "value": "BARK_CHANGES",
                  "text": "Changes in bark"
                },
                {
                  "value": "COUGHING",
                  "text": "Coughing or gagging"
                },
                {
                  "value": "HIND_END",
                  "text": "Hind-end weakness"
                },
                {
                  "value": "EXERCISE_INTOLERANCE",
                  "text": "Exercise and heat intolerance"
                }
              ],
              "showOtherItem": true,
              "showNoneItem": true,
              "noneText": "Don't know",
              "otherText": "Other (max 250 characters)"
            },
            {
              "type": "rating",
              "name": "SymptomsSeverity",
              "title": "How severe did you think {CmpnName}'s early symptoms were?",
              "description": "1 = mild, 5 = severe",
              "isRequired": true
            },
            {
              "type": "radiogroup",
              "name": "SymptomsNeckRestraint",
              "title": "Does/Did {CmpnName} have a history of pulling on a neck restraint or collar? ",
              "isRequired": true,
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false,
              "swapOrder": true
            }
          ]
        },
        {
          "type": "panel",
          "name": "SymptomsIntubationPanel",
          "elements": [
            {
              "type": "radiogroup",
              "name": "SymptomsIntubationWasIntubated",
              "title": "Had {CmpnName} been intubated under anesthesia for any reason in the 12 months prior to the first LP symptoms?",
              "isRequired": true,
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Not sure"
                }
              ]
            },
            {
              "type": "boolean",
              "name": "SymptomsIntubationConcerns",
              "title": "Do you remember having any concerns about how the intubation/anesthesia affected {CmpnName}?",
              "visibleIf": "{SymptomsIntubationWasIntubated} = 'YES'",
              "labelTrue": "Yes",
              "labelFalse": "No",
              "swapOrder": true,
              "isRequired": true
            },
            {
              "type": "checkbox",
              "name": "SymptomsIntubationSymptoms",
              "title": "What symptoms did {CmpnName} have after the intubation/anesthesia?",
              "visibleIf": "{SymptomsIntubationWasIntubated} = 'YES' && {SymptomsIntubationConcerns} = true",
              "choices": [
                {
                  "value": "COUGHING",
                  "text": "Coughing/hacking"
                },
                {
                  "value": "GAGGING",
                  "text": "Gagging/retching"
                },
                {
                  "value": "PANTING",
                  "text": "Excessive panting"
                },
                {
                  "value": "LABORED_BREATHING",
                  "text": "Labored breathing"
                }
              ],
              "choicesOrder": "none",
              "otherText": "Other",
              "showOtherItem": true
            }
          ]
        }
      ]
    },
    {
      "type": "panel",
      "name": "SymptomsCard2Panel",
      "elements": [
        {
          "type": "panel",
          "name": "SymptomsOtherConditionsPanel",
          "elements": [
            {
              "type": "radiogroup",
              "name": "SymptomsOtherConditions",
              "title": "When {CmpnName} first started showing symptoms of LP, did {cvGenderSubjectPronoun} have any other health conditions?",
              "isRequired": true,
              "choices": [
                {
                  "value": "YES",
                  "text": "Yes"
                },
                {
                  "value": "NO",
                  "text": "No"
                },
                {
                  "value": "DONT_KNOW",
                  "text": "Don't know"
                }
              ],
              "showOtherItem": false
            },
            {
            "type": "checkbox",
            "name": "SymptomsOtherConditionsType",
            "title": "Which other conditions did {CmpnName} have when the first LP symptoms appeared?",
            "isRequired": true,
            "visibleIf": "{SymptomsOtherConditions} = 'YES'",
            "choices": [
                {
                  "value": "GERD",
                  "text": "Acid reflux (GERD)"
                },
                {
                  "value": "ME",
                  "text": "Megaesophagus"
                },
                {
                  "value": "DM",
                  "text": "Degenerative Myelopathy"
                },
                {
                  "value": "ARTHRITIS",
                  "text": "Arthritis"
                },
                {
                  "value": "CUSHINGS",
                  "text": "Cushings"
                },
                {
                  "value": "CT",
                  "text": "Collapsing Trachea"
                },
                {
                  "value": "HYPOTHYROID",
                  "text": "Hypothyroidism"
                },
                {
                  "value": "HEMANGIOSARCOMA",
                  "text": "Hemangiosarcoma"
                }
              ],
              "choicesOrder": "none",
              "otherText": "Other (max. 250 characters)",
              "showOtherItem": true
            }
          ]
        }
        ]
    }
  ]
}